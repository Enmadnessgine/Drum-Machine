<Window x:Class="Drum_Machine.Views.LoadProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Project" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select a project to load:" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="ProjectsListBox" DisplayMemberPath="Title" SelectedValuePath="Id" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Load" Click="Load_Click" Width="80" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>