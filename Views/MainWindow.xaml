<Window x:Class="Drum_Machine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drum Machine" Height="570" Width="1100"
        Background="#1E1E1E">

    <Window.Resources>
        <Style x:Key="StepButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Background" Value="#444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" CornerRadius="4"
                                Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="Orange"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="▶ Play" Click="Play_Click" Background="OrangeRed" Margin="2" Width="60"/>
                <Button Content="■ Stop" Click="Stop_Click" Background="PaleVioletRed" Margin="2" Width="60"/>

                <ToggleButton x:Name="LoopButton"
                              Content="Loop"
                              Background="Aqua"
                              Margin="2"
                              Checked="Loop_Checked"
                              Unchecked="Loop_Unchecked"/>

                <Button Content="Load Project" Click="LoadProjectButton_Click" Margin="5"/>
                <Button Content="Save Project" Click="SaveProjectButton_Click" Width="100" Height="30" Margin="5"/>

                <Button Content="Export WAV" Click="ExportWavButton_Click" Width="100" Height="30" Margin="5"/>
                <Button Content="Add Track" Click="AddTrack_Click" Margin="10,2"/>

                <TextBlock Text="BPM:" Foreground="White" Margin="20,0,5,0" VerticalAlignment="Center"/>
                <Slider x:Name="BpmSlider"
                        Width="150"
                        Minimum="60"
                        Maximum="200"
                        Value="120"
                        ValueChanged="BpmSlider_ValueChanged"/>
                <TextBox x:Name="BpmTextBox"
                         Width="40"
                         Text="120"
                         Margin="5,0"
                         Background="#2D2D2D"
                         Foreground="White"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="UserNameTextBlock" 
                           Text="Nickname" 
                           Foreground="LightGray" 
                           VerticalAlignment="Center" 
                           Margin="0,0,15,0"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <Button x:Name="AccountActionButton"
                Content="Quit" 
                Click="AccountAction_Click"
                Padding="10,3"
                Background="#3D3D3D"
                Foreground="White"
                BorderThickness="1"
                BorderBrush="#555"
                Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="TracksPanel" Margin="10"/>
            </ScrollViewer>

            <Border Grid.Column="1" Background="#252525" BorderBrush="#333" BorderThickness="1,0,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SAMPLE LIBRARY" 
                               Foreground="#AAAAAA" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>

                    <ListBox x:Name="SampleListBox" 
                             Grid.Row="1"
                             Background="Transparent" 
                             BorderThickness="0" 
                             Foreground="White"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PreviewMouseLeftButtonDown="SampleListBox_PreviewMouseLeftButtonDown"
                             MouseMove="SampleListBox_MouseMove"
                             MouseDoubleClick="SampleListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="♪ " Foreground="Orange"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2" 
                            Content="+ Add sample" 
                            Click="AddSample_Click" 
                            Margin="0,10,0,0" 
                            Height="30" 
                            Background="#3D3D3D" 
                            Foreground="White"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>